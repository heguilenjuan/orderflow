datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
    output   = "./node_modules/@prisma/client"
}

model User {
    id             String   @id @default(uuid())
    name           String
    email          String   @unique
    type           Type     @default(standard)
    hasPendingDebt Boolean  @default(false)
    createdAt      DateTime @default(now())
    orders         Order[]
}

model Product {
    id        String   @id @default(uuid())
    name      String
    price     Decimal
    stock     Int      @default(1)
    createdAt DateTime @default(now())
    orders    Order[]

    @@index([name])
}

model Order {
    id         String   @id @default(uuid())
    user       User     @relation(fields: [userId], references: [id])
    userId     String
    product    Product  @relation(fields: [productId], references: [id])
    productId  String
    finalPrice Decimal
    createdAt  DateTime @default(now())

    @@index([userId, createdAt])
}

enum Type {
    premium
    standard
}
